{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/iucn-seed.ts",
    "validate-seed": "ts-node -r tsconfig-paths/register src/scripts/verify-with-iucn.ts",
    "image-search": "ts-node -r tsconfig-paths/register src/scripts/image-search.ts",
    "gbif-image-search": "ts-node -r tsconfig-paths/register src/scripts/gbif-image-search.ts",
    "url-species-script": "ts-node -r tsconfig-paths/register src/scripts/url-species-script.ts",
    "url-species-rebuild": "cross-env IMAGE_FILL_FORCE_REBUILD=true ts-node -r tsconfig-paths/register src/scripts/url-species-script.ts",
    "external-sync-batch": "ts-node -r tsconfig-paths/register src/scripts/external-sync-batch.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.16.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-validator": "^2.20.33",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
